      {goldLine}
    </div>
  );

  const progressBar = (val, max, color = colors.rose) => {
    const pct = Math.min(100, max > 0 ? (val / max) * 100 : 0);
    return (
      <div style={{ background: colors.beige, borderRadius: 20, height: 10, overflow: "hidden", marginTop: 6 }}>
        <div style={{ width: `${pct}%`, height: "100%", background: color, borderRadius: 20, transition: "width 0.4s" }} />
