            style={{ background: checkedDays[i] ? colors.gold : "#fff", borderRadius: 12, padding: "12px", cursor: "pointer", border: `1px solid ${checkedDays[i] ? colors.gold : colors.rose}`, transition: "all 0.2s" }}>
            <div style={{ fontFamily: fonts.sans, fontSize: 10, letterSpacing: 1, color: checkedDays[i] ? "#fff" : colors.gold, marginBottom: 4 }}>JOUR {i + 1}</div>
            <div style={{ fontFamily: fonts.sans, fontSize: 12, color: checkedDays[i] ? "#fff" : colors.text, lineHeight: 1.5 }}>{d}</div>
          </div>
        ))}
      </div>
      <div style={{ marginTop: 20, textAlign: "center" }}>
        <div style={{ fontFamily: fonts.serif, fontSize: 20, color: colors.brown }}>{checkedDays.filter(Boolean).length} / 30 jours</div>
        {progressBar(checkedDays.filter(Boolean).length, 30, colors.gold)}
        {checkedDays.filter(Boolean).length === 30 && <div style={{ marginTop: 12, fontFamily: fonts.serif, fontSize: 16, color: colors.gold }}>🏆 Félicitations ! Tu as complété ton Glow Up Financier !</div>}
      </div>
    </div>,

    // 7 - CHECKLIST
    <div style={{ padding: "28px 20px" }}>
      {sectionTitle("Money Habits of a Wealthy Woman", "Les habitudes simples qui changent tout")}
      <div style={{ background: colors.creme, borderRadius: 16, padding: "20px", marginBottom: 20, fontFamily: fonts.sans, fontSize: 13, color: colors.soft, lineHeight: 1.8 }}>
        Les femmes riches ne font pas des choses extraordinaires. Elles font des choses ordinaires, extraordinairement bien. Coche les habitudes que tu as déjà adoptées. 💎
      </div>
      {card(<>
        {habits.map((h, i) => (
          <div key={i} onClick={() => { const n = [...checkedHabits]; n[i] = !n[i]; setCheckedHabits(n); }}
            style={{ display: "flex", alignItems: "flex-start", gap: 12, padding: "14px 0", borderBottom: i < 9 ? `1px solid ${colors.beige}` : "none", cursor: "pointer" }}>
            <div style={{ width: 24, height: 24, borderRadius: "50%", border: `2px solid ${colors.gold}`, background: checkedHabits[i] ? colors.gold : "transparent", display: "flex", alignItems: "center", justifyContent: "center", flexShrink: 0 }}>
              {checkedHabits[i] && <span style={{ color: "#fff", fontSize: 13 }}>✓</span>}
            </div>
            <span style={{ fontFamily: fonts.sans, fontSize: 14, color: checkedHabits[i] ? colors.brown : colors.soft, lineHeight: 1.6, fontWeight: checkedHabits[i] ? 600 : 400 }}>{h}</span>
          </div>
        ))}
      </>)}
      <div style={{ textAlign: "center", marginTop: 8 }}>
        <div style={{ fontFamily: fonts.serif, fontSize: 22, color: colors.brown, marginBottom: 8 }}>{checkedHabits.filter(Boolean).length} / 10 habitudes</div>
        {progressBar(checkedHabits.filter(Boolean).length, 10, colors.gold)}
        <div style={{ marginTop: 12, fontFamily: fonts.sans, fontSize: 12, color: colors.soft }}>
          {checkedHabits.filter(Boolean).length < 4 ? "Tu débutes ton chemin — continue ! 🌱" :
           checkedHabits.filter(Boolean).length < 7 ? "Tu es sur la bonne voie ! 💪" :
           checkedHabits.filter(Boolean).length < 10 ? "Presque parfaite ! Tu brilles 🌟" : "Tu es une vraie Wealthy Woman ! 💎"}
        </div>
      </div>
      {goldLine}
      <div style={{ textAlign: "center", padding: "20px 0" }}>
        <div style={{ fontFamily: fonts.sans, fontSize: 11, letterSpacing: 2, color: colors.gold, marginBottom: 8 }}>✦ PLUME FINANCIÈRE ✦</div>
        <div style={{ fontFamily: fonts.serif, fontSize: 14, color: colors.soft, fontStyle: "italic" }}>
          "L'élégance financière, c'est savoir exactement où va chaque franc — et être en paix avec ça."
        </div>
      </div>
    </div>,
  ];

  return (
    <div style={{ minHeight: "100vh", background: colors.creme, fontFamily: fonts.sans }}>
      {nav}
      <div style={{ maxWidth: 480, margin: "0 auto" }}>
        {pages[active]}
      </div>
    </div>
  );
}
