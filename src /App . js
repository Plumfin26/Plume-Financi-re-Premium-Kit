          <div key={i} style={{ marginBottom: 14 }}>
            {label(cat)}
            {input(expenses[i], v => { const n = [...expenses]; n[i] = v; setExpenses(n); }, "Montant", "number")}
          </div>
        ))}
      </>)}
      {card(<>
        {label("Épargne prévue ce mois")}
        {input(savings, setSavings, "Montant à mettre de côté", "number")}
      </>)}
      {card(<>
        <div style={{ fontFamily: fonts.serif, fontSize: 16, color: colors.brown, marginBottom: 16 }}>Récapitulatif — {months[month]}</div>
