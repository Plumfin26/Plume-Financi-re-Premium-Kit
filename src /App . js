          <div style={{ fontFamily: fonts.sans, fontSize: 12, color: colors.soft, marginBottom: 14 }}>{p.desc}</div>
          {label("Montant alloué")}
          {input(p.val, p.set, "Ex: 75 000 FCFA", "number")}
        </div>
      ))}
      {(p1 + p2 + p3 > 0) && card(<>
        <div style={{ fontFamily: fonts.serif, fontSize: 16, color: colors.brown, marginBottom: 14 }}>Répartition de tes poches</div>
        {[["🏠 Essentielles", p1, colors.beige], ["💰 Épargne", p2, "#c5e8d0"], ["✨ Plaisir", p3, colors.rose]].map(([n, v, c]) => (
          <div key={n} style={{ marginBottom: 12 }}>
            <div style={{ display: "flex", justifyContent: "space-between", fontFamily: fonts.sans, fontSize: 13, color: colors.text }}>
              <span>{n}</span><span>{v.toLocaleString()} FCFA</span>
            </div>
            {progressBar(v, totalPoches, c)}
          </div>
        ))}
        {incomeNum > 0 && <div style={{ marginTop: 12, fontFamily: fonts.sans, fontSize: 12, color: totalPoches > incomeNum ? "#e07070" : "#6aaa80" }}>
          {totalPoches > incomeNum ? "⚠️ Total supérieur à ton revenu. Rééquilibre tes poches." : `✦ Il reste ${(incomeNum - totalPoches).toLocaleString()} FCFA non alloués.`}
        </div>}
      </>)}
    </div>,

    // 3 - TRACKER
    <div style={{ padding: "28px 20px" }}>
      {sectionTitle("Tracker Financier", "Suis tes dépenses avec style")}
      {card(<>
        <div style={{ fontFamily: fonts.serif, fontSize: 16, color: colors.brown, marginBottom: 16 }}>Objectif financier du mois</div>
        {label("Nom de l'objectif")}
        {input(goalName, setGoalName, "Ex: Rembourser un prêt, Voyage, Téléphone...")}
        <div style={{ marginTop: 12 }} />
        {label("Montant cible")}
        {input(goal, setGoal, "Ex: 50 000 FCFA", "number")}
        {goal && savings && <>
          <div style={{ marginTop: 16, fontFamily: fonts.sans, fontSize: 13, color: colors.text }}>
            Progression : {Math.min(100, Math.round(((parseFloat(savings)||0) / (parseFloat(goal)||1)) * 100))}%
          </div>
          {progressBar(parseFloat(savings)||0, parseFloat(goal)||1, colors.gold)}
          <div style={{ marginTop: 6, fontFamily: fonts.sans, fontSize: 12, color: colors.soft }}>
            Basé sur ton épargne mensuelle du Budget Planner
          </div>
        </>}
      </>)}
      {card(<>
        <div style={{ fontFamily: fonts.serif, fontSize: 16, color: colors.brown, marginBottom: 16 }}>Journal des dépenses</div>
        {trackerRows.map((row, i) => (
          <div key={i} style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 10, marginBottom: 14, paddingBottom: 14, borderBottom: i < 7 ? `1px solid ${colors.beige}` : "none" }}>
            <div>
              {label("Description")}
              {input(row.label, v => { const n = [...trackerRows]; n[i] = { ...n[i], label: v }; setTrackerRows(n); }, "Ex: Courses")}
            </div>
            <div>
              {label("Montant")}
              {input(row.amount, v => { const n = [...trackerRows]; n[i] = { ...n[i], amount: v }; setTrackerRows(n); }, "FCFA", "number")}
            </div>
          </div>
        ))}
        <button onClick={() => setTrackerRows([...trackerRows, { label: "", amount: "", cat: "" }])}
          style={{ background: colors.rose, border: "none", borderRadius: 20, padding: "8px 20px", fontFamily: fonts.sans, fontSize: 13, color: colors.brown, cursor: "pointer", marginTop: 8 }}>
          + Ajouter une dépense
        </button>
        {goldLine}
        <div style={{ display: "flex", justifyContent: "space-between", fontFamily: fonts.serif, fontSize: 16, color: colors.brown }}>
          <span>Total suivi</span>
          <span>{trackerRows.reduce((s, r) => s + (parseFloat(r.amount) || 0), 0).toLocaleString()} FCFA</span>
        </div>
      </>)}
    </div>,

    // 4 - MINDSET
    <div style={{ padding: "28px 20px" }}>
      {sectionTitle("Mindset Money Girl", "Reprogramme ta relation avec l'argent")}
      {[
        { title: "Arrête de dépenser par émotion", content: "La dépense émotionnelle, c'est acheter pour combler un vide — ennui, tristesse, stress. Avant chaque achat non planifié, pose-toi 3 questions : Est-ce que j'en ai vraiment besoin ? Est-ce dans mon budget ? Est-ce que j'aurais fait cet achat hier si je n'étais pas dans cet état ?" },
        { title: "Deviens constante avec l'argent", content: "La richesse ne vient pas d'un mois exceptionnel. Elle vient de la régularité. 5 000 FCFA épargnés chaque mois valent mieux que 50 000 FCFA épargnés une fois. Crée un système, pas une motivation." },
        { title: "Ta routine financière (10 min/semaine)", content: "Chaque dimanche : ouvre ton application bancaire, vérifie tes dépenses, transfère ton épargne, fixe un mini-objectif pour la semaine. C'est tout. 10 minutes suffisent pour changer ta vie financière." },
        { title: "L'argent n'est pas tabou", content: "Dans nos cultures, parler d'argent peut sembler impoli. Mais le silence financier nous coûte cher. Parle d'argent avec tes proches, tes amies. Apprends. Pose des questions. La honte ne paie pas les factures." },
      ].map((s, i) => (
        <div key={i} style={{ background: i % 2 === 0 ? colors.creme : colors.beige, borderRadius: 16, padding: "22px", marginBottom: 16, border: `1px solid ${colors.rose}` }}>
          <div style={{ fontFamily: fonts.serif, fontSize: 17, color: colors.brown, marginBottom: 10 }}>✦ {s.title}</div>
          <div style={{ fontFamily: fonts.sans, fontSize: 13, color: colors.soft, lineHeight: 1.9, marginBottom: 16 }}>{s.content}</div>
          {label("Ma réflexion personnelle")}
          <textarea value={mindsetNotes[Math.min(i, 2)]} onChange={e => { const n = [...mindsetNotes]; n[Math.min(i, 2)] = e.target.value; setMindsetNotes(n); }}
