        { num: 2, name: "Épargne & Objectifs", desc: "Ton futur. Ton matelas de sécurité. Tes projets. Tu paies d'abord ton futur moi.", emoji: "💰", color: "#f0ede8", val: poche2, set: setPoche2, pct: "20-30%" },
        { num: 3, name: "Plaisir Sans Culpabilité", desc: "Shopping, sorties, beauté, gâteries. Tu le mérites — dans ta limite.", emoji: "✨", color: "#fde8f0", val: poche3, set: setPoche3, pct: "10-20%" },
