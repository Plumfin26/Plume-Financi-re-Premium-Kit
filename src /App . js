          {months.map((m, i) => <option key={i} value={i}>{m}</option>)}
        </select>
      </>)}
      {card(<>
        {label("Revenu net du mois")}
        {input(income, setIncome, "Ex: 150 000 FCFA", "number")}
        {income && <div style={{ marginTop: 8, fontFamily: fonts.sans, fontSize: 12, color: colors.soft }}>Revenu enregistré ✦</div>}
      </>)}
      {card(<>
        <div style={{ fontFamily: fonts.serif, fontSize: 16, color: colors.brown, marginBottom: 16 }}>Mes dépenses par catégorie</div>
