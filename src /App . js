            style={{ width: "100%", border: "none", borderBottom: `1.5px solid ${colors.rose}`, padding: "8px 4px", fontFamily: fonts.sans, fontSize: 13, color: colors.text, background: "transparent", outline: "none", resize: "none", minHeight: 60, boxSizing: "border-box" }} />
        </div>
