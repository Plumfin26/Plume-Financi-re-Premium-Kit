      </div>
      {card(<>
        <div style={{ fontFamily: fonts.serif, fontSize: 16, color: colors.brown, marginBottom: 16 }}>✅ Ma checklist du dimanche</div>
        {[
          { key: "depenses", label: "J'ai vérifié mes dépenses de la semaine", val: routine.depenses, set: v => setRoutine({ ...routine, depenses: v }) },
          { key: "ajustement", label: "J'ai ajusté mon budget si nécessaire", val: routine.ajustement, set: v => setRoutine({ ...routine, ajustement: v }) },
